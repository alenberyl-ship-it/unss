# Configuration de l'Application UNSS Goma

# Clé secrète pour les sessions (Générez une clé forte !)
SECRET_KEY=your_super_secret_key_here_change_me_in_production

# Configuration du serveur de mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True

# Identifiants email (Gmail recommandé)
# Note: Pour Gmail, utilisez un mot de passe d'application, pas le mot de passe principal
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# Email par défaut pour les envois
MAIL_DEFAULT_SENDER=noreply@sauveteursgoma.org

# Email de destination pour les messages de contact
CONTACT_EMAIL=contact@sauveteursgoma.org
